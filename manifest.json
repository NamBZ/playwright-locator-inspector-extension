{
  "manifest_version": 3,
  "name": "Playwright Locator Inspector",
  "version": "1.0.0",
  "description": "Hover to inspect elements and generate Playwright locator strings. Click to copy.",
  "icons": {
    "16": "icons/icon-16.png",
    "24": "icons/icon-24.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "24": "icons/icon-24.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "Toggle Playwright Locator Inspector"
  },
  "permissions": ["activeTab", "clipboardWrite", "scripting"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "toggle-inspector": {
      "suggested_key": {
        "default": "Alt+L"
      },
      "description": "Toggle Playwright Locator Inspector"
    }
  }
}
